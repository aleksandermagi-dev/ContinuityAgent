{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Continuity Layer",
  "version": "0.1.0",
  "identifier": "dev.aleksandermagi.continuitylayer",
  "build": {
    "beforeDevCommand": "npm run dev:client",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/client"
  },
  "app": {
    "windows": [
      {
        "title": "Continuity Layer",
        "width": 1280,
        "height": 860,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Continuity Layer",
    "windows": {
      "nsis": {
        "displayLanguageSelector": false
      }
    }
  }
}
